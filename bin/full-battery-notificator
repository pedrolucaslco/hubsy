#!/bin/bash

SERVICE_DIR="$HOME/.config/systemd/user"
SERVICE_FILE="$SERVICE_DIR/bateria-95.service"
SCRIPT_DIR="$HOME/.local/bin"
SCRIPT_FILE="$SCRIPT_DIR/bateria-95.sh"

enable_service() {
  mkdir -p "$SERVICE_DIR" "$SCRIPT_DIR"

  cat > "$SCRIPT_FILE" << 'EOF'
#!/bin/bash
while true; do
  BAT=$(upower -e | grep BAT | head -n1)
  LEVEL=$(upower -i "$BAT" | awk '/percentage/ {gsub("%",""); print $2}')
  STATE=$(upower -i "$BAT" | awk '/state/ {print $2}')

  if [ "$LEVEL" -ge 95 ] && [ "$STATE" = "charging" ]; then
    notify-send -u critical "Bateria em $LEVEL%" "Pode remover o carregador"
    sleep 300
  fi

  sleep 60
done
EOF

  chmod +x "$SCRIPT_FILE"

  cat > "$SERVICE_FILE" << EOF
[Unit]
Description=Alerta de bateria em 95%

[Service]
ExecStart=$SCRIPT_FILE
Restart=always

[Install]
WantedBy=default.target
EOF

  systemctl --user daemon-reload
  systemctl --user enable bateria-95.service
  systemctl --user start bateria-95.service

  echo "Serviço ATIVADO"
}

disable_service() {
  systemctl --user stop bateria-95.service 2>/dev/null
  systemctl --user disable bateria-95.service 2>/dev/null

  rm -f "$SERVICE_FILE" "$SCRIPT_FILE"

  systemctl --user daemon-reload

  echo "Serviço DESATIVADO"
}

case "$1" in
  enable) enable_service ;;
  disable) disable_service ;;
  *)
    echo "Uso: $0 {enable|disable}"
    exit 1
    ;;
esac
